# Video2TechBlog Configuration
DEEPSEEK_API_KEY=sk-your-api-key-here
MIMO_API_KEY=your-mimo-api-key-here
# Token Plan keys (tp-...) use https://token-plan-cn.xiaomimimo.com/v1 by default.
# Standard API keys use https://api.xiaomimimo.com/v1 by default.
# MIMO_BASE_URL=
# MIMO_ASR_MODEL=mimo-v2.5-asr
# MIMO_ASR_LANGUAGE=zh
# MIMO_ASR_CHUNK_SECONDS=180
# MIMO_ASR_MP3_BITRATE=32k
# MIMO_ASR_CONCURRENCY=3
# MIMO_ASR_TIMEOUT_SECONDS=90
# MIMO_ASR_MAX_ATTEMPTS=2
# MIMO_ASR_HEARTBEAT_SECONDS=10
# MIMO_ASR_FALLBACK_RETRY=0
# WHISPER_LANGUAGE=zh
# WHISPER_MODEL_SIZE=large-v3
# WHISPER_DEVICE=cpu

# Optional: cookies file for yt-dlp (Bilibili, YouTube login-required content)
# Export from browser using "Get cookies.txt LOCALLY" extension
# YTDLP_COOKIES_PATH=
